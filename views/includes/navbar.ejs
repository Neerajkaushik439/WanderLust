<style>
  .search-btn i {
    margin-right: 6px;

  }

  .search-btn {
    display: inline-flex;
    align-items: center;
    border-radius: 30px;
    padding: 0.5rem 1.5rem !important;
    background-color: #ff385c !important;
    color: white !important;
    font-weight: 500;
    transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), background-color 0.25s ease, box-shadow 0.25s ease !important;
    box-shadow: 0 4px 6px rgba(255, 56, 92, 0.15);
  }

  .search-btn:hover {
    background-color: #e61e4d !important;
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(255, 56, 92, 0.3);
  }

  .search-btn:active {
    transform: translateY(0);
  }

  .search-input {
    border-radius: 30px;
    padding: 0.5rem 3rem 0.5rem 3rem;
    font-size: 1rem;
  }

  .hover-highlight:hover {
    background-color: #e0e0e0;
    /* Replace with desired color */
    border-radius: 25px;
    /* Optional for rounded corners */

  }

  .navbar-nav .nav-btn, a.nav-btn {
    display: inline-flex;
    align-items: center;
    border-radius: 25px;
    background-color: #ff385c !important;
    color: white !important;
    text-decoration: none !important;
    padding: 0.5rem 1.2rem !important;
    font-weight: 500;
    transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), background-color 0.25s ease, box-shadow 0.25s ease !important;
    box-shadow: 0 4px 6px rgba(255, 56, 92, 0.15);
    margin-top: auto;
    margin-bottom: auto;
  }

  .navbar-nav .nav-btn:hover, a.nav-btn:hover {
    background-color: #e61e4d !important;
    color: white !important;
    text-decoration: none !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 6px 12px rgba(255, 56, 92, 0.3);
  }

  .navbar-nav .nav-btn:active, a.nav-btn:active {
    transform: translateY(0) !important;
  }
</style>
<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">

        <a class="nav-link" href="/listings">Explore</a>


      </div>
      <div class="navbar-nav ms-auto" id="searchbox">
        <form class="d-flex" role="search" action="/listings" method="GET">
          <input class="form-control me-2 search-input" type="search" name="q" placeholder="Search destination"
            value="<%= typeof q !== 'undefined' ? q : '' %>" aria-label="Search" />
          <button class="btn search-btn" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i> Search
          </button>
        </form>
      </div>


      <div class="navbar-nav ms-auto">
        <a class="me-3 nav-btn" href="/listings/new">Wanderlust your home</a>

        <li class="nav-item dropdown">

          <a class="nav-link " href="#" role="button" data-bs-toggle="dropdown">
            <i class="fa-solid fa-user fa-lg"></i>

          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <% if (typeof currentUser !=='undefined' && currentUser) { %>
              <li><a class="dropdown-item" href="/logout">Logout</a></li>
              <% } else { %>
                <li><a class="dropdown-item" href="/login">Login</a></li>
                <li><a class="dropdown-item" href="/signup">Signup</a></li>
                <% } %>


      </div>
    </div>
  </div>
</nav>