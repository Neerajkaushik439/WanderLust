<% layout('layouts/boilerplate') -%>
<body>
  <div class="row">
    <div class="col-8 offset-2">
      <h3>Create a New Listing</h3>
      <form action="/listings" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">

        <div>
          <label for="title" class="form-label">Title</label>
          <input type="text" name="listing[title]" id="title" class="form-control" required>
          <div class="invalid-feedback">Please enter a title</div>
        </div>
        <br><br>

        <div>
          <label for="description" class="form-label">Description</label>
          <textarea name="listing[description]" id="description" class="form-control" required></textarea>
          <div class="invalid-feedback">Please enter a short description</div>
          <br><br>
        </div>

        <div class="row">
          <div class="col-md-4">
            <label for="price" class="form-label">Price</label>
            <input type="number" name="listing[price]" id="price" class="form-control" required>
            <div class="invalid-feedback">Please enter a valid price</div>
            <br><br>
          </div>
          <div class="col-md-8">
            <label for="country" class="form-label">Country</label>
            <input type="text" name="listing[country]" id="country" class="form-control" required>
            <div class="invalid-feedback">Please enter a country name</div>
            <br><br>
          </div>
        </div>

        <div>
          <label for="location" class="form-label">Location</label>
          <input type="text" name="listing[location]" id="location" class="form-control" required>
          <div class="invalid-feedback">Please enter a valid location</div>
          <br><br>
        </div>

        <div class="row">
          <div class="col-md-4">
            <label for="guests" class="form-label">Max Guests</label>
            <input type="number" name="listing[guests]" id="guests" class="form-control" min="1" value="1" required>
            <div class="invalid-feedback">Please enter guest capacity</div>
            <br><br>
          </div>
          <div class="col-md-4">
            <label for="bedrooms" class="form-label">Bedrooms</label>
            <input type="number" name="listing[bedrooms]" id="bedrooms" class="form-control" min="0" value="0" required>
            <div class="invalid-feedback">Please enter number of bedrooms</div>
            <br><br>
          </div>
          <div class="col-md-4">
            <label for="bathrooms" class="form-label">Bathrooms</label>
            <input type="number" name="listing[bathrooms]" id="bathrooms" class="form-control" min="0" value="0" required>
            <div class="invalid-feedback">Please enter number of bathrooms</div>
            <br><br>
          </div>
        </div>

        <div>
          <label class="form-label">Facilities / Amenities</label>
          <div class="row">
            <div class="col-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="listing[amenities]" value="Fast WiFi" id="amenity-wifi">
                <label class="form-check-label" for="amenity-wifi">Fast WiFi</label>
              </div>
            </div>
            <div class="col-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="listing[amenities]" value="Mountain view" id="amenity-view">
                <label class="form-check-label" for="amenity-view">Mountain view</label>
              </div>
            </div>
            <div class="col-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="listing[amenities]" value="Free parking" id="amenity-parking">
                <label class="form-check-label" for="amenity-parking">Free parking</label>
              </div>
            </div>
            <div class="col-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="listing[amenities]" value="Kitchen" id="amenity-kitchen">
                <label class="form-check-label" for="amenity-kitchen">Kitchen</label>
              </div>
            </div>
            <div class="col-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="listing[amenities]" value="Washer" id="amenity-washer">
                <label class="form-check-label" for="amenity-washer">Washer</label>
              </div>
            </div>
            <div class="col-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="listing[amenities]" value="AC" id="amenity-ac">
                <label class="form-check-label" for="amenity-ac">AC</label>
              </div>
            </div>
          </div>
          <br><br>
        </div>

      
        <div class="container">
            <p class="row1">Enter details of image</p>
            <div class="row">
                <div class="pair2 col-md-12">
                    <label for="image" class="form-label">Upload Listing Image</label>
                    <input type="file" name="listing[image]" id="image" class="form-control" required >
                    <!-- <div id="validationServer04Feedback" class="invalid-feedback">Please enter a valid URL</div> -->
                </div>
            </div>
        </div>
        <br><br>

        <button class="btn btn-custom">Submit</button>
        <br><br>
      </form>
    </div>
  </div>
</body>

